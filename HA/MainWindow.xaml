<Window.Resources>
    <!-- Style cho các nút bấm thiết bị trên Dashboard -->
    <Style x:Key="DeviceButtonStyle" TargetType="ContentControl">
        <Setter Property="Canvas.Left" Value="{Binding X, Mode=TwoWay}"/>
        <Setter Property="Canvas.Top" Value="{Binding Y, Mode=TwoWay}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border x:Name="Border" 
                            Background="{Binding StatusColor}" 
                            CornerRadius="8" 
                            Width="160" Height="100" 
                            BorderThickness="2" 
                            BorderBrush="Transparent"
                            Margin="5"
                            Cursor="{Binding CursorType}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Opacity="0.2" ShadowDepth="2"/>
                        </Border.Effect>
                        <Grid>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="💡" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White" TextAlignment="Center" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding EntityId}" FontSize="10" Foreground="#E0E0E0" TextAlignment="Center" Opacity="0.8"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="#FFEB3B"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Style chung cho Button UI -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="#0078D4"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="15,8"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.9"/>
            </Trigger>
        </Style.Triggers>
    </Style>
</Window.Resources>

<Grid>
    <TabControl FontSize="14" Margin="0" Background="White" BorderThickness="0">
        <!-- TAB 1: WEB VIEW -->
        <TabItem Header="🌐 Camera &amp; Web">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#F9F9F9" Padding="10" BorderBrush="#DDD" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📍 URL Hiện tại:" VerticalAlignment="Center" Margin="5,0,10,0" Foreground="#666"/>
                        <TextBlock x:Name="lblCurrentUrl" Text="Chưa kết nối" VerticalAlignment="Center" FontWeight="Bold" Foreground="#0078D4"/>
                    </StackPanel>
                </Border>
                <wv2:WebView2 Name="haWebView" Grid.Row="1" />
            </Grid>
        </TabItem>

        <!-- TAB 2: DASHBOARD (CHẾ ĐỘ KÉO THẢ) -->
        <TabItem Header="⚡ Dashboard">
            <Grid Background="#E9EBEE">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Thanh công cụ chỉnh sửa -->
                <Border Grid.Row="0" Background="White" Padding="10" BorderBrush="#CCC" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="btnToggleEdit" Content="🛠️ Chế độ Sửa" Padding="15,5" Margin="0,0,10,0" Click="BtnToggleEdit_Click"/>
                        
                        <StackPanel x:Name="pnlEditTools" Orientation="Horizontal" Visibility="Collapsed">
                            <Button Content="↔️ Xếp Ngang" Background="#607D8B" Margin="0,0,5,0" Click="BtnAlignHorizontal_Click"/>
                            <Button Content="↕️ Xếp Dọc" Background="#607D8B" Margin="0,0,20,0" Click="BtnAlignVertical_Click"/>
                            <Button Content="💾 Lưu Vị Trí" Background="#4CAF50" Click="BtnSaveLayout_Click"/>
                            <TextBlock Text="* Giữ Ctrl để chọn nhiều" VerticalAlignment="Center" Margin="10,0" FontStyle="Italic" Foreground="#666"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Vùng Canvas hiển thị thiết bị -->
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icDashboard">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Width="2000" Height="2000" Background="Transparent" 
                                        MouseDown="Canvas_MouseDown"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentControl" BasedOn="{StaticResource DeviceButtonStyle}">
                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="Device_MouseDown"/>
                                <EventSetter Event="PreviewMouseMove" Handler="Device_MouseMove"/>
                                <EventSetter Event="PreviewMouseLeftButtonUp" Handler="Device_MouseUp"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </TabItem>

        <!-- TAB 3: CÀI ĐẶT -->
        <TabItem Header="⚙️ Cài Đặt">
            <ScrollViewer>
                <Grid Margin="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cấu hình HA -->
                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="CẤU HÌNH HỆ THỐNG" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" Foreground="#333"/>
                        
                        <TextBlock Text="Home Assistant URL:" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtUrlSetting" Padding="10" Margin="0,0,0,15"/>

                        <TextBlock Text="Long-Lived Access Token:" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtTokenSetting" Padding="10" Margin="0,0,0,20" Height="100" TextWrapping="Wrap" AcceptsReturn="True"/>

                        <Button Content="🚀 LƯU VÀ KẾT NỐI" Height="45" Background="#0078D4" Click="BtnSaveAndConnect_Click"/>
                    </StackPanel>

                    <!-- Thêm thiết bị mới -->
                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                        <TextBlock Text="THÊM THIẾT BỊ MỚI" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" Foreground="#333"/>

                        <TextBlock Text="Tên hiển thị (Ví dụ: Đèn Phòng Khách):" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtNewDeviceName" Padding="10" Margin="0,0,0,15"/>

                        <TextBlock Text="Entity ID (Ví dụ: light.den_khach):" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtNewDeviceEntity" Padding="10" Margin="0,0,0,20"/>

                        <Button Content="➕ THÊM VÀO DASHBOARD" Height="45" Background="#4CAF50" Click="BtnAddDevice_Click"/>
                        
                        <TextBlock Text="* Sau khi thêm, qua tab Dashboard bật chế độ Sửa để kéo vị trí." 
                                   FontStyle="Italic" Foreground="#888" Margin="0,20,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</Grid>
