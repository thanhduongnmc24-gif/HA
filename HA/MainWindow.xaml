<Window x:Class="HA.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Home Assistant Smart Controller" Height="768" Width="1366"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <TabControl FontSize="15" Margin="5" Background="White" BorderThickness="0">
            <TabItem Header="🌐 Camera &amp; Web">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#F9F9F9" Padding="5" BorderBrush="#DDD" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📍 Đang kết nối:" VerticalAlignment="Center" Margin="5,0,10,0" Foreground="#666" FontSize="12"/>
                            <TextBlock x:Name="lblCurrentUrl" Text="Chưa kết nối" VerticalAlignment="Center" FontWeight="Bold" Foreground="#0078D4" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <wv2:WebView2 Name="haWebView" Grid.Row="1" />
                </Grid>
            </TabItem>

            <TabItem Header="⚡ Điều Khiển Nhanh">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="BẢNG ĐIỀU KHIỂN" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30" Foreground="#333"/>
                    <Button Content="💡 Bật/Tắt Đèn Khách" Width="280" Height="50" Margin="0,0,0,10" Click="BtnToggleDevice_Click" Tag="light.den_khach"/>
                    <Button Content="💡 Bật/Tắt Đèn Ngủ" Width="280" Height="50" Margin="0,0,0,10" Click="BtnToggleDevice_Click" Tag="light.den_ngu"/>
                    <Button Content="🔌 Bật/Tắt Quạt" Width="280" Height="50" Margin="0,0,0,10" Click="BtnToggleDevice_Click" Tag="switch.quat_tran"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="⚙️ Cài Đặt">
                <Grid Margin="50">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        <TextBlock Text="CẤU HÌNH KẾT NỐI" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                        
                        <TextBlock Text="Đường dẫn Home Assistant (URL):" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtUrlSetting" Padding="8" Margin="0,0,0,15"/>

                        <TextBlock Text="Mã truy cập (Long-Lived Access Token):" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtTokenSetting" Padding="8" Margin="0,0,0,20" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>

                        <Button Content="🚀 LƯU VÀ KẾT NỐI NGAY" Height="45" Background="#4CAF50" Click="BtnSaveAndConnect_Click"/>
                        
                        <TextBlock Text="* Lưu ý: Token được lấy trong phần Profile -> Security của Home Assistant." 
                                   FontStyle="Italic" Foreground="#888" Margin="0,15,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>