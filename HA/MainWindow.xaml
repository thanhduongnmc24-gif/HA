<Window x:Class="HA.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Home Assistant Controller" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen">
    <TabControl FontSize="16">
        <TabItem Header="🌐 Camera &amp; Giao Diện Web">
            <Grid>
                <wv2:WebView2 Name="haWebView" />
            </Grid>
        </TabItem>

        <TabItem Header="⚡ Điều Khiển Nhanh (API)">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="BẢNG ĐIỀU KHIỂN THIẾT BỊ" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                
                <Button Content="💡 Bật/Tắt Đèn Khách" Width="250" Height="60" FontSize="18" Margin="0,0,0,15" Click="BtnToggleDevice_Click" Tag="light.den_khach"/>
                
                <Button Content="💡 Bật/Tắt Đèn Ngủ" Width="250" Height="60" FontSize="18" Margin="0,0,0,15" Click="BtnToggleDevice_Click" Tag="light.den_ngu"/>
                
                <Button Content="🔌 Bật/Tắt Quạt" Width="250" Height="60" FontSize="18" Margin="0,0,0,15" Click="BtnToggleDevice_Click" Tag="switch.quat_tran"/>
            </StackPanel>
        </TabItem>
    </TabControl>
</Window>